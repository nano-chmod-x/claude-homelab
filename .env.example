# Homelab environment template
# Copy to ~/.claude-homelab/.env and replace placeholder values.
# Keep real secrets out of git.

# Plex
# Skills
PLEX_URL=https://your-plex-url
PLEX_TOKEN=your_plex_token

# Overseerr
# Skills
OVERSEERR_URL=https://your-overseerr-url
OVERSEERR_API_KEY=your_api_key
# MCP
OVERSEERR_MCP_TOKEN=your_mcp_bearer_token
OVERSEERR_MCP_TRANSPORT=streamable-http
OVERSEERR_MCP_HOST=0.0.0.0
OVERSEERR_MCP_PORT=9151
OVERSEERR_LOG_LEVEL=DEBUG
OVERSEERR_MCP_NO_AUTH=true

# Radarr
# Skills
RADARR_URL=https://your-radarr-url
RADARR_API_KEY=your_api_key
RADARR_DEFAULT_QUALITY_PROFILE=1

# Sonarr
# Skills
SONARR_URL=https://your-sonarr-url
SONARR_API_KEY=your_api_key
SONARR_DEFAULT_QUALITY_PROFILE=1

# Prowlarr
# Skills
PROWLARR_URL=https://your-prowlarr-url
PROWLARR_API_KEY=your_api_key

# Tautulli
# Skills
TAUTULLI_URL=https://your-tautulli-url
TAUTULLI_API_KEY=your_api_key

# SABnzbd
# Skills
SABNZBD_URL=https://your-sabnzbd-url
SABNZBD_API_KEY=your_api_key

# qBittorrent
# Skills
QBITTORRENT_URL=https://your-qbittorrent-url
QBITTORRENT_USERNAME=your_username
QBITTORRENT_PASSWORD=your_password

# Unraid
# Skills
UNRAID_SERVER1_NAME=your_server1_name
UNRAID_SERVER1_URL=https://your-unraid-server1/graphql
UNRAID_SERVER1_API_KEY=your_api_key
UNRAID_SERVER2_NAME=your_server2_name
UNRAID_SERVER2_URL=https://your-unraid-server2/graphql
UNRAID_SERVER2_API_KEY=your_api_key
# MCP
UNRAID_MCP_BEARER_TOKEN=your_mcp_bearer_token
UNRAID_API_URL=https://your-unraid-server/graphql
UNRAID_API_KEY=your_api_key
UNRAID_MCP_TRANSPORT=streamable-http
UNRAID_MCP_PORT=6970
UNRAID_MCP_HOST=0.0.0.0
UNRAID_MCP_LOG_LEVEL=INFO
UNRAID_MCP_ALLOW_DESTRUCTIVE=false
UNRAID_MCP_ALLOW_YOLO=false
UNRAID_MCP_DISABLE_HTTP_AUTH=true

# UniFi
# Skills
UNIFI_URL=https://your-unifi-controller
UNIFI_USERNAME=your_username
UNIFI_PASSWORD=your_password
UNIFI_SITE=default
# MCP
UNIFI_MCP_TOKEN=your_mcp_bearer_token
UNIFI_CONTROLLER_URL=https://your-unifi-controller:443
UNIFI_VERIFY_SSL=false
UNIFI_IS_UDM_PRO=true
UNIFI_MCP_HOST=0.0.0.0
UNIFI_MCP_PORT=8001
UNIFI_LOCAL_MCP_HOST=0.0.0.0
UNIFI_LOCAL_MCP_PORT=8001
UNIFI_LOCAL_MCP_LOG_LEVEL=DEBUG
UNIFI_LOCAL_MCP_LOG_FILE=unifi_local_mcp.log
UNIFI_MCP_NO_AUTH=true

# SWAG
# Skills
SWAG_HOST=your_host
SWAG_CONTAINER_NAME=swag
SWAG_APPDATA_PATH=/mnt/appdata/swag
SWAG_COMPOSE_PATH=/mnt/compose/swag
# MCP
SWAG_MCP_TOKEN=your_mcp_bearer_token
SWAG_MCP_PROXY_CONFS_URI=your_host:/mnt/appdata/swag/nginx/proxy-confs
SWAG_MCP_LOG_DIRECTORY=/mnt/appdata/swag-mcp/logs
SWAG_MCP_DEFAULT_AUTH_METHOD=authelia
SWAG_MCP_DEFAULT_QUIC_ENABLED=false
SWAG_MCP_BACKUP_RETENTION_DAYS=30
SWAG_MCP_HOST=0.0.0.0
SWAG_MCP_PORT=8012
SWAG_MCP_LOG_LEVEL=INFO
SWAG_MCP_LOG_FILE_ENABLED=true
SWAG_MCP_LOG_FILE_MAX_BYTES=10485760
SWAG_MCP_RATE_LIMIT_ENABLED=false
SWAG_MCP_RATE_LIMIT_RPS=10.0
SWAG_MCP_RATE_LIMIT_BURST=20
SWAG_MCP_LOG_PAYLOADS=false
SWAG_MCP_LOG_PAYLOAD_MAX_LENGTH=1000
SWAG_MCP_SLOW_OPERATION_THRESHOLD_MS=1000
SWAG_MCP_ENABLE_STRUCTURED_LOGGING=false
SWAG_MCP_ENABLE_RETRY_MIDDLEWARE=true
SWAG_MCP_MAX_RETRIES=3
SWAG_MCP_NO_AUTH=true

# Synapse
# MCP
SYNAPSE_MCP_TOKEN=your_mcp_bearer_token
SYNAPSE_ALLOW_ROOT_LOGIN=true
SYNAPSE_MCP_ALLOW_DESTRUCTIVE=true
SYNAPSE_MCP_NO_AUTH=1
SYNAPSE_MCP_HOST=0.0.0.0
SYNAPSE_MCP_PORT=8014
SYNAPSE_MCP_ALLOWED_HOSTS=
SYNAPSE_EXCLUDE_HOSTS=
SYNAPSE_CONFIG_FILE=/config/synapse.config.json

# Arcane
# MCP
ARCANE_MCP_TOKEN=your_mcp_bearer_token
ARCANE_API_KEY=your_arcane_api_key
ARCANE_API_URL=https://your-arcane-url
ARCANE_MCP_TRANSPORT=http
ARCANE_MCP_BIND_PORT=3000
ARCANE_MCP_PORT=44332
ARCANE_MCP_AUTH_ENABLED=false
ARCANE_MCP_ALLOW_YOLO=false
ARCANE_MCP_ALLOW_DESTRUCTIVE=false

# Syslog
# MCP
SYSLOG_MCP_TOKEN=your_mcp_bearer_token
SYSLOG_MCP_TRANSPORT=http
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=1514
SYSLOG_MCP_HOST=0.0.0.0
SYSLOG_MCP_PORT=3100
SYSLOG_MCP_DB_PATH=/data/syslog.db
SYSLOG_MCP_POOL_SIZE=4
SYSLOG_MCP_RETENTION_DAYS=90
SYSLOG_MCP_MAX_DB_SIZE_MB=10240
SYSLOG_MCP_RECOVERY_DB_SIZE_MB=9216
RUST_LOG=info
SYSLOG_MCP_DATA_VOLUME=./data
NO_AUTH=true

# Tailscale
# Skills
TAILSCALE_API_KEY=your_api_key
TAILSCALE_TAILNET=your_tailnet_or_dash

# ZFS
# Skills
ZFS_HOST=your_zfs_host

# Gotify
# Skills
GOTIFY_URL=https://your-gotify-url
GOTIFY_TOKEN=your_token
# MCP
GOTIFY_MCP_TOKEN=your_mcp_bearer_token
GOTIFY_APP_TOKEN=your_gotify_app_token
GOTIFY_CLIENT_TOKEN=your_gotify_client_token
GOTIFY_MCP_TRANSPORT=http
GOTIFY_MCP_HOST=0.0.0.0
GOTIFY_MCP_PORT=9158
GOTIFY_LOG_LEVEL=DEBUG
GOTIFY_MCP_NO_AUTH=true

# Linkding
# Skills
LINKDING_URL=https://your-linkding-url
LINKDING_API_KEY=your_api_key

# Memos
# Skills
MEMOS_URL=https://your-memos-url
MEMOS_API_TOKEN=your_memos_api_token

# Bytestash
# Skills
BYTESTASH_URL=https://your-bytestash-url
BYTESTASH_API_KEY=your_api_key

# Paperless-ngx
# Skills
PAPERLESS_URL=https://your-paperless-url
PAPERLESS_API_TOKEN=your_api_token

# Radicale
# Skills
RADICALE_URL=https://your-radicale-url
RADICALE_USERNAME=your_username
RADICALE_PASSWORD=your_password

# Axon
# MCP
AXON_MCP_TOKEN=your_mcp_bearer_token
AXON_API_URL=https://your-axon-url
AXON_API_KEY=your_api_key
AXON_MCP_HOST=0.0.0.0
AXON_MCP_PORT=8016
AXON_LOG_LEVEL=INFO

# NotebookLM
# Skills
NOTEBOOKLM_COOKIE=your_notebooklm_cookie
NOTEBOOKLM_AUTH_JSON='{"cookies": [...]}'
NOTEBOOKLM_LOG_LEVEL=INFO

# Glances
# Skills
GLANCES_URL=http://your-glances-host:61208
GLANCES_USERNAME=
GLANCES_PASSWORD=

# GitHub
# Skills
GITHUB_TOKEN=your_github_token

# Shared runtime vars
# A few MCP repos still read these generic names directly. Keep a single copy here.
ALLOW_DESTRUCTIVE=false
ALLOW_YOLO=false
DOCKER_NETWORK=your_docker_network
LOG_LEVEL=info
